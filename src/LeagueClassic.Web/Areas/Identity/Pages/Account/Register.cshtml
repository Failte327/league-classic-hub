@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="page-head"><h1>Create your account</h1></div>

<div class="auth-card">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
        </div>
        <div class="field">
            <label asp-for="Input.DisplayName"></label>
            <input asp-for="Input.DisplayName" class="form-control" autocomplete="off" placeholder="Your public name on the site" />
            <span class="field-hint">This is your calling card. Your email is never shown publicly.</span>
        </div>
        <div class="field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" class="form-control" type="password" autocomplete="new-password" />
        </div>
        <div class="field">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">Register</button>
        </div>
        <p class="muted">Already have an account? <a asp-page="/Account/Login">Log in</a>.</p>
    </form>
</div>
