@inject SignInManager<ApplicationUser> SignInManager
@inject LeagueClassic.Web.Services.DiscordService Discord
@{
    var discordCount = await Discord.GetMemberCountAsync();
    // Central spot for the site-identity metadata every page needs — canonical
    // URL, description, and social preview tags. Individual pages can override
    // the description via ViewData["Description"] before this layout renders.
    const string SiteUrl = "https://leagueclassicarchive.net";
    const string DiscordInviteUrl = "https://discord.gg/rzVYaqPkQ9";
    var pageTitle = ViewData["Title"] as string ?? "League Classic Archive";
    var description = ViewData["Description"] as string
        ?? "Guides, champion info, forums, and community tournaments for League Classic — Riot's legacy throwback mode.";
    var canonicalUrl = SiteUrl + Context.Request.Path;
    var ogImage = SiteUrl + "/assets/brand/league-classic-logo.png";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>League Classic Archive - @pageTitle</title>
    <meta name="description" content="@description" />
    <link rel="canonical" href="@canonicalUrl" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="League Classic Archive" />
    <meta property="og:title" content="League Classic Archive - @pageTitle" />
    <meta property="og:description" content="@description" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:image" content="@ogImage" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="League Classic Archive - @pageTitle" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImage" />

    <link rel="stylesheet" href="~/css/classic.css" asp-append-version="true" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9565092722653347"
            crossorigin="anonymous"></script>
    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-UlGglu96jzfFAAc3ovpaj.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
</head>
<body>
    <div class="site-wrap">
        <header class="site-header">
            <div class="masthead">
                <a class="logo" asp-page="/Index">
                    <img src="~/assets/brand/league-classic-logo.png" alt="League Classic" />
                </a>
                <span class="site-title">League Classic Archive</span>
                <a class="discord-badge" href="@DiscordInviteUrl" target="_blank" rel="noopener" title="Join our Discord">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                        <path d="M20.32 4.37a19.8 19.8 0 0 0-4.89-1.52.07.07 0 0 0-.08.04c-.21.38-.45.87-.61 1.26a18.3 18.3 0 0 0-5.48 0 12.6 12.6 0 0 0-.62-1.26.08.08 0 0 0-.08-.04 19.7 19.7 0 0 0-4.89 1.52.07.07 0 0 0-.03.03C1.24 8.68.48 12.86.85 16.98a.08.08 0 0 0 .03.06 19.9 19.9 0 0 0 5.99 3.03.08.08 0 0 0 .08-.03c.46-.63.87-1.3 1.23-2a.08.08 0 0 0-.04-.11 13.1 13.1 0 0 1-1.87-.9.08.08 0 0 1-.01-.13c.13-.09.25-.19.37-.28a.08.08 0 0 1 .08-.01c3.93 1.79 8.18 1.79 12.06 0a.08.08 0 0 1 .08.01c.12.1.24.19.37.28a.08.08 0 0 1-.01.13c-.6.35-1.22.65-1.87.9a.08.08 0 0 0-.04.11c.36.7.77 1.37 1.23 2a.08.08 0 0 0 .08.03 19.8 19.8 0 0 0 6-3.03.08.08 0 0 0 .03-.06c.44-4.77-.74-8.92-3.13-12.58a.06.06 0 0 0-.03-.03ZM8.68 14.44c-1.18 0-2.15-1.08-2.15-2.42 0-1.33.95-2.41 2.15-2.41 1.21 0 2.17 1.09 2.15 2.41 0 1.34-.94 2.42-2.15 2.42Zm6.65 0c-1.18 0-2.15-1.08-2.15-2.42 0-1.33.95-2.41 2.15-2.41 1.21 0 2.17 1.09 2.15 2.41 0 1.34-.93 2.42-2.15 2.42Z"/>
                    </svg>
                    Discord
                    @if (discordCount is { } dc)
                    {
                        <span class="discord-count">@dc.Online.ToString("N0") online</span>
                    }
                </a>
                <partial name="_LoginPartial" />
            </div>
            <nav class="mainnav">
                <a asp-page="/Index">Home</a>
                <a asp-page="/Forums/Index">Forums</a>
                <a asp-page="/Guides/Index">Guides</a>
                <a asp-page="/Champions/Index">Champions</a>
                <a asp-page="/Resources/Items">Resources</a>
                <a asp-page="/Tournaments/Index">Tournaments</a>
                <a href="@DiscordInviteUrl" target="_blank" rel="noopener">Discord</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-page="/Guides/Mine">My Guides</a>
                }
                @if (User.IsInRole(DbSeeder.ModeratorRole))
                {
                    <a class="nav-mod" asp-page="/Moderation/Index">Moderation</a>
                    <a class="nav-mod" asp-page="/Moderation/DevUpdates">Post Update</a>
                    <a class="nav-mod" asp-page="/Stats/Index">Stats</a>
                }
                <a asp-page="/Rules">Rules</a>
            </nav>
        </header>

        @* Header ad slot disabled for now — re-add when ready:
        <partial name="_AdSlot" model="@("8492928602")" />
        *@

        <main class="content">
            @RenderBody()
        </main>

        <partial name="_AdSlot" model="@("1752380579")" />

        <footer class="site-footer">
            <p>&copy; 2026 League Classic Archive &middot; a fan site &middot;
            <a asp-page="/Rules">Rules</a> &middot; <a asp-page="/Privacy">Privacy</a></p>
            <p class="disclaimer">
                League Classic Archive is not endorsed by Riot Games and does not reflect the
                views or opinions of Riot Games or anyone officially involved in producing or managing
                Riot Games properties. Riot Games and all associated properties are trademarks or
                registered trademarks of Riot Games, Inc. League of Legends&copy; Riot Games, Inc.
                Champion, item, and ability art is the property of Riot Games and is used here under
                Riot&rsquo;s Legal Jibber Jabber policy for fan content.
            </p>
        </footer>
    </div>

    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
