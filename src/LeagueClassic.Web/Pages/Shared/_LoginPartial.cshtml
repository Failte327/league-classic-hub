@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="user-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li><a asp-area="Identity" asp-page="/Account/Manage/Index">@UserManager.GetUserName(User)</a></li>
    <li>
        <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post">
            <button type="submit" class="linklike">Log out</button>
        </form>
    </li>
}
else
{
    <li><a asp-area="Identity" asp-page="/Account/Register">Register</a></li>
    <li><a asp-area="Identity" asp-page="/Account/Login">Log in</a></li>
}
</ul>
