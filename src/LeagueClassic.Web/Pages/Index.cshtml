@page
@model IndexModel
@{
    ViewData["Title"] = "Guides, Discussion, Lore";
    ViewData["Description"] = "League Classic Archive is a fan-run hub for League Classic: champion guides, build info, forums, and community tournaments for Riot's legacy throwback mode.";
}

<section class="hero">
    @if (Model.HeroSplash is not null)
    {
        <div class="hero-bg" style="background-image:url('/@Model.HeroSplash')"></div>
    }
    <h1>Welcome, Summoners!</h1>
    <p class="hero-lede">
        Welcome to League Classic Archive, a sanctuary for weary Summoners after a long day
        on the Fields of Justice, and a well of knowledge for wide-eyed newcomers looking to
        discover the ancient builds of old. A place where League Classic enjoyers old and new can
        discuss the game we all love, which has returned at long last! Good luck and have fun!
    </p>
    <div class="hero-cta">
        <a class="btn-primary" asp-page="/Guides/Index">Browse Guides</a>
        <a class="btn-plain" asp-page="/Forums/Index">Visit the Forums</a>
    </div>
</section>

<div class="home-grid">
    <section class="home-col">
        <div class="section-head">
            <h2>Latest Guides</h2>
            <a class="see-all" asp-page="/Guides/Index">See all &raquo;</a>
        </div>
        @if (Model.LatestGuides.Count == 0)
        {
            <div class="empty">No guides published yet — be the first to write one!</div>
        }
        else
        {
            <div class="guide-cards">
                @foreach (var g in Model.LatestGuides)
                {
                    <a class="guide-card" asp-page="/Guides/Details" asp-route-slug="@g.Slug">
                        @if (g.Champion?.IconPath is not null)
                        {
                            <img src="~/@g.Champion.IconPath" alt="@g.Champion.Name" />
                        }
                        <span class="gc-body">
                            <span class="gc-title">@g.Title</span>
                            <span class="gc-meta">@g.Champion?.Name &middot; by @g.Author.Display("staff")</span>
                        </span>
                    </a>
                }
            </div>
        }
    </section>

    <section class="home-col home-side">
        <div class="section-head">
            <h2>Latest Discussion</h2>
            <a class="see-all" asp-page="/Forums/Index">Forums &raquo;</a>
        </div>
        @if (Model.LatestThreads.Count == 0)
        {
            <div class="empty">The forums are quiet… for now.</div>
        }
        else
        {
            <ul class="thread-feed">
                @foreach (var t in Model.LatestThreads)
                {
                    <li>
                        <a asp-page="/Forums/Thread" asp-route-id="@t.Id" asp-route-slug="@t.Slug">
                            @if (t.IsPinned) { <span class="pin" title="Pinned">📌</span> }
                            @t.Title
                        </a>
                        <span class="tf-meta">@t.Author.Display("staff") &middot; @t.LastPostAt.ToString("MMM d")</span>
                    </li>
                }
            </ul>
        }
    </section>
</div>
