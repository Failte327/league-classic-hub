@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@model LeagueClassic.Web.Pages.Forums.IndexModel
@{
    ViewData["Title"] = "Forums";
}

<div class="forum-banner">
    <div class="forum-bg" style="background-image:url('/assets/forum-bg/@(Model.ForumBg)')"></div>
    <div class="page-head">
        <div>
            <h1>League Classic Hub Forums</h1>
            <p class="muted">Welcome, Summoner, to the Fields of Justice!</p>
        </div>
        @if (SignInManager.IsSignedIn(User))
        {
            <a class="btn-primary" asp-page="/Forums/NewThread">+ New Thread</a>
        }
        else
        {
            <a class="btn-primary" asp-area="Identity" asp-page="/Account/Login">Log in to post</a>
        }
    </div>
</div>

@if (Model.Pinned.Count == 0 && Model.Threads.Count == 0)
{
    <div class="empty">No threads yet. Start the conversation!</div>
}
else
{
    <ul class="thread-list">
        @foreach (var t in Model.Pinned)
        {
            <partial name="_ThreadRow" model="(t, true)" />
        }
        @foreach (var t in Model.Threads)
        {
            <partial name="_ThreadRow" model="(t, false)" />
        }
    </ul>
}
