@page "{slug}"
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@model LeagueClassic.Web.Pages.Forums.BoardModel
@{
    ViewData["Title"] = Model.Board.Name;
}

<nav class="crumbs"><a asp-page="/Forums/Index">Forums</a> &raquo; <span>@Model.Board.Name</span></nav>

<div class="page-head">
    <div>
        <h1>@Model.Board.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Board.Description))
        {
            <p class="muted">@Model.Board.Description</p>
        }
    </div>
    @if (SignInManager.IsSignedIn(User))
    {
        <a class="btn-primary" asp-page="/Forums/NewThread" asp-route-board="@Model.Board.Slug">+ New Thread</a>
    }
    else
    {
        <a class="btn-primary" asp-area="Identity" asp-page="/Account/Login">Log in to post</a>
    }
</div>

@if (Model.Threads.Count == 0)
{
    <div class="empty">No threads yet. Start the conversation!</div>
}
else
{
    <table class="forum-table">
        <caption class="cat-header">Threads</caption>
        <thead>
            <tr><th>Topic</th><th class="stat">Author</th><th class="stat">Replies</th><th class="stat">Last Post</th></tr>
        </thead>
        <tbody>
        @foreach (var t in Model.Threads)
        {
            <tr>
                <td class="board-name">
                    @if (t.IsPinned)
                    {
                        <span class="pin" title="Pinned">📌</span>
                    }
                    @if (t.IsLocked)
                    {
                        <span class="lock" title="Locked">🔒</span>
                    }
                    <a asp-page="/Forums/Thread" asp-route-id="@t.Id" asp-route-slug="@t.Slug">@t.Title</a>
                </td>
                <td class="stat">@(t.Author?.UserName ?? "staff")</td>
                <td class="stat">@t.ReplyCount</td>
                <td class="stat">@t.LastPostAt.ToString("MMM d, yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
}
