@page
@model LeagueClassic.Web.Pages.Reference.ItemsModel
@{
    ViewData["Title"] = "Items";
}

<partial name="_Tabs" model="@("Items")" />

<p class="muted">Every classic item, on its own — hover for the old stats and passives.</p>

@foreach (var group in Model.ByCategory)
{
    <div class="item-group">
        <h3>@group.Key</h3>
        <div class="item-row">
            @foreach (var item in group)
            {
                <div class="item-opt" data-name="@item.Name" data-desc="@item.Description">
                    <img src="~/@item.IconPath" alt="@item.Name" loading="lazy" />
                    <span class="item-opt-name">@item.Name</span>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/hover-panel.js" asp-append-version="true"></script>
}
