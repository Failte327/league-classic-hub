@model LeagueClassic.Web.Pages.Guides.GuideEditorVm

<form method="post" class="guide-form" id="guide-form">
    <input type="hidden" asp-for="Input.ChampionSlug" />
    <input type="hidden" asp-for="Input.SpellOneId" id="spell-one" />
    <input type="hidden" asp-for="Input.SpellTwoId" id="spell-two" />
    <input type="hidden" asp-for="Input.SkillOrder" id="skill-order" />
    <input type="hidden" asp-for="Input.BuildOrderCsv" id="build-order" />
    <input type="hidden" asp-for="Input.RunesCsv" id="runes-csv" />
    <input type="hidden" asp-for="Input.MasteryAllocations" id="mastery-alloc" />

    <div asp-validation-summary="All" class="validation-summary"></div>

    <div class="field">
        <label asp-for="Input.Title">Guide Title</label>
        <input asp-for="Input.Title" placeholder="e.g. AP @(Model.Champion.Name) Mid — Season 3 Domination" />
    </div>

    <!-- Summoner spells -->
    <section class="panel">
        <h2>Summoner Spells <small>(pick two)</small></h2>
        <div class="spell-palette" id="spell-palette">
            @foreach (var s in Model.Spells)
            {
                <button type="button" class="spell-opt" data-id="@s.Id"
                        data-name="@s.Name" data-desc="@s.Description">
                    <img src="~/@s.IconPath" alt="@s.Name" loading="lazy" />
                    <span>@s.Name</span>
                </button>
            }
        </div>
    </section>

    <!-- Runes -->
    <section class="panel">
        <h2>Runes <small>(click a rune to add it; adjust the count on the chip)</small></h2>
        <div class="rune-summary" id="rune-summary">
            <span class="build-empty">No runes yet — pick from the slots below.</span>
        </div>
        <div class="rune-palette" id="rune-palette">
            @foreach (var group in Model.RunesBySlot)
            {
                <div class="rune-group">
                    <h3>@group.Key</h3>
                    <div class="rune-row">
                        @foreach (var r in group)
                        {
                            <button type="button" class="rune-opt" data-id="@r.Id" data-slot="@r.Slot"
                                    data-name="@r.Name" data-icon="@r.IconPath" data-desc="@r.Description">
                                <img src="~/@r.IconPath" alt="@r.Name" loading="lazy" />
                                <span>@r.Name.Replace("Greater ", "")</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Masteries -->
    <section class="panel">
        <h2>Masteries <small>(30 points — click to add, right-click to remove)</small></h2>
        <div class="mastery-summary">
            <span class="ms-off">Offense <b id="mt-Offense">0</b></span>
            <span class="ms-def">Defense <b id="mt-Defense">0</b></span>
            <span class="ms-uti">Utility <b id="mt-Utility">0</b></span>
            <span class="ms-rem"><b id="mt-remaining">30</b> points left</span>
        </div>
        <div class="mastery-trees">
            @foreach (var tree in new[] { "Offense", "Defense", "Utility" })
            {
                <div class="mastery-tree">
                    <div class="mt-head mt-head-@tree.ToLower()">@tree</div>
                    <div class="mt-grid" data-tree="@tree">
                        @foreach (var m in Model.Masteries.Where(x => x.Tree == tree))
                        {
                            <button type="button" class="mastery-node"
                                    style="grid-column:@(m.Col + 1);grid-row:@m.Row"
                                    data-id="@m.DdragonId" data-tree="@m.Tree" data-row="@m.Row"
                                    data-ranks="@m.Ranks" data-prereq="@(m.PrereqDdragonId?.ToString() ?? "")"
                                    data-name="@m.Name" data-desc="@m.Description">
                                <img src="~/@m.IconPath" alt="@m.Name" loading="lazy" />
                                <span class="mn-pts">0/@m.Ranks</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Ability leveling -->
    <section class="panel">
        <h2>Ability Leveling <small>(click a cell to put the level's point into that ability)</small></h2>

        <div class="ability-bar">
            @foreach (var slot in new[] { "P", "Q", "W", "E", "R" })
            {
                if (Model.AbilityBySlot.TryGetValue(slot, out var ab))
                {
                    <span class="ability-chip" title="@ab.Name">
                        <span class="slot-key slot-@slot">@slot</span>
                        @if (ab.IconPath is not null)
                        {
                            <img src="~/@ab.IconPath" alt="@ab.Name" />
                        }
                        <span class="ability-name">@ab.Name</span>
                    </span>
                }
            }
        </div>

        @{
            var gridAbilities = new[] { "Q", "W", "E", "R" }.ToDictionary(
                s => s,
                s => Model.AbilityBySlot.TryGetValue(s, out var a)
                    ? new { name = a.Name, icon = a.IconPath }
                    : new { name = s, icon = (string?)null });
        }
        <script type="application/json" id="champ-abilities">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(gridAbilities))</script>
        <script type="application/json" id="initial-state">@Html.Raw(Model.InitialStateJson)</script>
        <div class="skill-grid" id="skill-grid"></div>
        <p class="hint">R (ultimate) can only be leveled at 6, 11, and 16.</p>
    </section>

    <!-- Build order -->
    <section class="panel">
        <h2>Item Build Order</h2>
        <div class="build-strip" id="build-strip">
            <span class="build-empty">Click items below to add them to the build in order.</span>
        </div>
        <div class="item-palette">
            @foreach (var group in Model.ItemsByCategory)
            {
                <div class="item-group">
                    <h3>@group.Key</h3>
                    <div class="item-row">
                        @foreach (var item in group)
                        {
                            <button type="button" class="item-opt" data-id="@item.Id"
                                    data-name="@item.Name" data-icon="@item.IconPath" data-desc="@item.Description">
                                <img src="~/@item.IconPath" alt="@item.Name" loading="lazy" />
                                <span class="item-opt-name">@item.Name</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Body -->
    <section class="panel">
        <h2>Guide Details</h2>
        <div class="markdown-help">
            <strong>Formatting:</strong>
            <code>**bold**</code> or <code>&lt;b&gt;bold&lt;/b&gt;</code> &middot;
            <code>*italic*</code> &middot;
            <code># Heading</code> &middot;
            <code>- list item</code> &middot;
            <code>[link](https://…)</code> &middot;
            <code>`code`</code> &middot; blank line = new paragraph.
        </div>
        <div class="editor-split">
            <textarea asp-for="Input.BodyMarkdown" rows="18"
                      placeholder="Explain the playstyle, matchups, combos, power spikes…"
                      hx-post="/guides/preview" hx-trigger="load, keyup changed delay:400ms"
                      hx-target="#md-preview" hx-swap="innerHTML"></textarea>
            <div class="md-preview-wrap">
                <div class="md-preview-label">Live Preview</div>
                <div id="md-preview" class="md-preview guide-body"></div>
            </div>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" name="Input.Publish" value="false" class="btn-plain">Save as Draft</button>
        <button type="submit" name="Input.Publish" value="true" class="btn-primary">
            @(Model.IsEdit ? "Update & Publish" : "Publish Guide")
        </button>
    </div>
</form>
