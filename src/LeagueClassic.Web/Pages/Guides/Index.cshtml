@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@model LeagueClassic.Web.Pages.Guides.IndexModel
@{
    ViewData["Title"] = "Guides";
}

<div class="forum-banner">
    <div class="forum-bg" style="background-image:url('/assets/forum-bg/@(Model.BannerBg)')"></div>
    <div class="page-head">
        <h1>Guides &amp; Builds</h1>
        @if (SignInManager.IsSignedIn(User))
        {
            <a class="btn-primary" asp-page="/Guides/Create">+ Create Guide</a>
        }
        else
        {
            <a class="btn-primary" asp-area="Identity" asp-page="/Account/Login">Log in to create a guide</a>
        }
    </div>
</div>
<p class="muted">Community-written guides and builds.</p>

@if (Model.Guides.Count == 0)
{
    <div class="empty">No published guides yet — be the first to write one!</div>
}
else
{
    <table class="forum-table">
        <caption class="cat-header">Latest Guides</caption>
        <thead>
            <tr><th>Champion</th><th>Guide</th><th class="stat">Author</th><th class="stat">Updated</th></tr>
        </thead>
        <tbody>
        @foreach (var g in Model.Guides)
        {
            <tr>
                <td class="champ-cell">
                    @if (g.Champion?.IconPath is not null)
                    {
                        <img src="~/@g.Champion.IconPath" alt="@g.Champion.Name" class="champ-icon-sm" />
                    }
                    <span>@g.Champion?.Name</span>
                </td>
                <td class="board-name">
                    <a asp-page="/Guides/Details" asp-route-slug="@g.Slug">@g.Title</a>
                </td>
                <td class="stat">@g.Author.Display("staff")</td>
                <td class="stat">@g.UpdatedAt.ToString("MMM d, yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
}
