@page "{slug}"
@model LeagueClassic.Web.Pages.Guides.DetailsModel
@inject MarkdownRenderer Markdown
@{
    ViewData["Title"] = Model.Guide.Title;
    var abilities = new[] { "Q", "W", "E", "R" };
}

<article class="guide-view">
    <header class="guide-header">
        @if (Model.Guide.Champion?.Slug is not null)
        {
            <div class="guide-bg" style="background-image:url('/assets/splash/@(Model.Guide.Champion.Slug).jpg')"></div>
        }
        @if (Model.Guide.Champion?.IconPath is not null)
        {
            <img src="~/@Model.Guide.Champion.IconPath" alt="@Model.Guide.Champion.Name" class="champ-icon-lg" />
        }
        <div>
            <h1>@Model.Guide.Title</h1>
            <div class="guide-meta">
                @Model.Guide.Champion?.Name &middot;
                by @(Model.Guide.Author?.UserName ?? "unknown") &middot;
                @Model.Guide.UpdatedAt.ToString("MMM d, yyyy")
                @if (Model.Guide.Status != GuideStatus.Published)
                {
                    <span class="badge-draft">@Model.Guide.Status</span>
                }
            </div>
        </div>
        @if (Model.CanEdit)
        {
            <div class="owner-actions">
                <a class="mini-btn" asp-page="/Guides/Edit" asp-route-id="@Model.Guide.Id">Edit</a>
                <form method="post" asp-page="/Guides/Mine" asp-page-handler="Delete" asp-route-id="@Model.Guide.Id"
                      onsubmit="return confirm('Delete this guide? This cannot be undone.');">
                    <button type="submit" class="mini-btn danger">Delete</button>
                </form>
            </div>
        }
    </header>

    <div class="loadout">
        <!-- Summoner spells -->
        @if (Model.Guide.SpellOne is not null || Model.Guide.SpellTwo is not null)
        {
            <div class="loadout-block">
                <h3>Summoner Spells</h3>
                <div class="spell-show">
                    @foreach (var s in new[] { Model.Guide.SpellOne, Model.Guide.SpellTwo })
                    {
                        if (s is not null)
                        {
                            <span class="spell-badge"><img src="~/@s.IconPath" alt="@s.Name" /> @s.Name</span>
                        }
                    }
                </div>
            </div>
        }

        <!-- Build order -->
        @if (Model.Guide.BuildOrder.Count > 0)
        {
            <div class="loadout-block">
                <h3>Build Order</h3>
                <div class="build-show">
                    @{ var n = 1; }
                    @foreach (var bi in Model.Guide.BuildOrder)
                    {
                        <span class="build-item" title="@bi.Item?.Name">
                            <span class="ord">@(n++)</span>
                            <img src="~/@bi.Item?.IconPath" alt="@bi.Item?.Name" />
                        </span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Abilities overview -->
    @if (Model.AbilityBySlot.Count > 0)
    {
        <div class="loadout-block">
            <h3>Abilities</h3>
            <div class="ability-bar">
                @foreach (var slot in new[] { "P", "Q", "W", "E", "R" })
                {
                    if (Model.AbilityBySlot.TryGetValue(slot, out var ab))
                    {
                        <span class="ability-chip" title="@ab.Name">
                            <span class="slot-key slot-@slot">@slot</span>
                            @if (ab.IconPath is not null)
                            {
                                <img src="~/@ab.IconPath" alt="@ab.Name" />
                            }
                            <span class="ability-name">@ab.Name</span>
                        </span>
                    }
                }
            </div>
        </div>
    }

    <!-- Skill order -->
    @if (Model.SkillLevels.Count > 0)
    {
        <div class="loadout-block">
            <h3>Ability Leveling</h3>
            <table class="skill-table read-only">
                <thead>
                    <tr>
                        <th></th>
                        @for (var lvl = 1; lvl <= Model.SkillLevels.Count; lvl++)
                        {
                            <th>@lvl</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ab in abilities)
                    {
                        Model.AbilityBySlot.TryGetValue(ab, out var info);
                        <tr>
                            <th class="ab-label ab-@ab" title="@info?.Name">
                                @if (info?.IconPath is not null)
                                {
                                    <img src="~/@info.IconPath" alt="@info.Name" />
                                }
                                <span class="slot-key slot-@ab">@ab</span>
                            </th>
                            @for (var i = 0; i < Model.SkillLevels.Count; i++)
                            {
                                var on = Model.SkillLevels[i] == ab;
                                <td><span class="skill-cell @(on ? "on" : "")"></span></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Body -->
    <div class="guide-body">
        @Markdown.ToHtml(Model.Guide.BodyMarkdown)
    </div>

    <p><a asp-page="/Guides/Index">&larr; All guides</a></p>
</article>
