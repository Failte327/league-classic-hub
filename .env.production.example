# On the server: cp .env.production.example .env, then fill in real values.
# This file (docker-compose.prod.yml's .env) is separate from the dev-only
# .env.example at the repo root — never reuse the dev Postgres password here.
POSTGRES_PASSWORD=replace-with-a-long-random-password
DOMAIN=leagueclassicarchive.net
ACME_EMAIL=timothy.twelker@gmail.com

# SES SMTP credentials (SES console -> SMTP settings -> Create SMTP credentials).
# These are NOT your AWS account access key/secret — SES generates a separate
# SMTP username/password pair. Leave unset and the app just logs emails
# instead of sending (fine for a first deploy before SES is set up).
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
